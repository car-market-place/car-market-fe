{
    "$schema": "https://json.schemastore.org/tsconfig",
  
    "compilerOptions": {
      "target": "ES2022",
      "lib": [
        "ES2022"
      ],
  
      "strict": true,
  
      "module": "ESNext",
      "moduleResolution": "Bundler",
  
      "skipLibCheck": true,
  
      "resolveJsonModule": true,
  
      "isolatedModules": true,
  
      "noEmit": true
    }
  }